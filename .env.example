# Environment variables for stormshield-mcp
# Copy to .env and fill in your values

# Device passwords (referenced as ${VAR_NAME} in config.yaml)
PARIS_FW_PASSWORD=your_password_here
LYON_FW_PASSWORD=your_password_here

# Optional: override config values
# SNS_MCP_SERVER__PORT=8765
# SNS_MCP_LOGGING__LEVEL=DEBUG
